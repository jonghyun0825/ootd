# Supabase 프로젝트 설정 값을 입력하세요.
# Supabase 대시보드 > Project Settings > API 에서 확인할 수 있습니다.

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# 주의:
# - anon key는 공개되어도 되는 키입니다 (Row Level Security로 보호됩니다).
# - service_role key는 절대 이 파일이나 프론트엔드 코드에 넣지 마세요.
# - 실제 값을 입력한 파일의 이름은 .env 로 저장하고, .env 파일은 git에 커밋하지 마세요.
